# Inos web local config — copy to `.env.local` for development.

# API base URL (defaults to http://localhost:4000)
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Bearer token sent with every API request (Issue #3).
# v1 limitation: this is a SHARED SECRET that ships in the browser bundle.
# It MUST match `INOS_API_TOKEN` in apps/api/.env. Upgrade path is per-user
# JWTs once we have a user model.
# NEXT_PUBLIC_INOS_API_TOKEN=replace-me-with-the-same-string-as-INOS_API_TOKEN
