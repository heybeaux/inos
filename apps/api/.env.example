# Inos API local config — copy to `.env` for development.
#
# Persistence (Issue #2)
DATABASE_URL="file:./inos.db"

# LLM (optional for ingestion / query)
# OPENROUTER_API_KEY=

# Auth (Issue #3) — required for all non-/health routes in v1.
# INOS_API_TOKEN=replace-me-with-a-long-random-secret

# CORS (Issue #16) — comma-separated list of allowed Origins.
# Defaults to localhost:3000/3001/3003 if unset.
# INOS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
